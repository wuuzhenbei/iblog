        <servlet-class>com.iblog.servlet.blog.BlogListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BlogListServlet</servlet-name>
        <url-pattern>/api/blogs/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BlogDetailServlet</servlet-name>
        <servlet-class>com.iblog.servlet.blog.BlogDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BlogDetailServlet</servlet-name>
        <url-pattern>/api/blogs/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BlogEditServlet</servlet-name>
        <servlet-class>com.iblog.servlet.blog.BlogEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BlogEditServlet</servlet-name>
        <url-pattern>/api/blogs/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BlogInteractionServlet</servlet-name>
        <servlet-class>com.iblog.servlet.blog.BlogInteractionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BlogInteractionServlet</servlet-name>
        <url-pattern>/api/blogs/interact</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DraftServlet</servlet-name>
        <servlet-class>com.iblog.servlet.blog.DraftServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DraftServlet</servlet-name>
        <url-pattern>/api/blogs/drafts</url-pattern>
    </servlet-mapping>

    <!-- ==================== Comment Servlets ==================== -->
    <servlet>
        <servlet-name>CommentServlet</servlet-name>
        <servlet-class>com.iblog.servlet.blog.CommentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
