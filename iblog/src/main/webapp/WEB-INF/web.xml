        <servlet-class>com.iblog.servlet.chat.MessageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MessageServlet</servlet-name>
        <url-pattern>/api/messages</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ConversationServlet</servlet-name>
        <servlet-class>com.iblog.servlet.chat.ConversationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConversationServlet</servlet-name>
        <url-pattern>/api/messages/conversations</url-pattern>
    </servlet-mapping>

    <!-- ==================== AI Servlets ==================== -->
    <servlet>
        <servlet-name>AiCopywritingServlet</servlet-name>
        <servlet-class>com.iblog.servlet.ai.AiCopywritingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AiCopywritingServlet</servlet-name>
