<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>iBlog</display-name>

    <!-- ==================== Filters ==================== -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.iblog.filter.EncodingFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.iblog.filter.AuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.iblog.filter.AdminFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/user/*</url-pattern>
        <url-pattern>/api/blogs</url-pattern>
        <url-pattern>/api/social/*</url-pattern>
        <url-pattern>/api/messages/*</url-pattern>
        <url-pattern>/api/ai/*</url-pattern>
        <url-pattern>/api/sign</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/api/admin/*</url-pattern>
    </filter-mapping>

    <!-- ==================== Auth Servlets ==================== -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.iblog.servlet.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/api/auth/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.iblog.servlet.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/auth/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.iblog.servlet.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/api/auth/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CaptchaServlet</servlet-name>
        <servlet-class>com.iblog.servlet.auth.CaptchaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CaptchaServlet</servlet-name>
        <url-pattern>/api/auth/captcha</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PasswordResetServlet</servlet-name>
        <servlet-class>com.iblog.servlet.auth.PasswordResetServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PasswordResetServlet</servlet-name>
        <url-pattern>/api/auth/reset-password</url-pattern>
    </servlet-mapping>

    <!-- ==================== User Servlets ==================== -->
    <servlet>
        <servlet-name>UserProfileServlet</servlet-name>
        <servlet-class>com.iblog.servlet.user.UserProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserProfileServlet</servlet-name>
        <url-pattern>/api/user/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserPrivacyServlet</servlet-name>
        <servlet-class>com.iblog.servlet.user.UserPrivacyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserPrivacyServlet</servlet-name>
        <url-pattern>/api/user/privacy</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserStatusServlet</servlet-name>
        <servlet-class>com.iblog.servlet.user.UserStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserStatusServlet</servlet-name>
        <url-pattern>/api/user/status</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserLevelServlet</servlet-name>
        <servlet-class>com.iblog.servlet.user.UserLevelServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserLevelServlet</servlet-name>
        <url-pattern>/api/user/level</url-pattern>
    </servlet-mapping>

    <!-- ==================== Blog Servlets ==================== -->
    <servlet>
        <servlet-name>BlogPublishServlet</servlet-name>
        <servlet-class>com.iblog.servlet.blog.BlogPublishServlet</servlet-class>
    </servlet>
    <servlet-mapping>
