        <servlet-class>com.iblog.servlet.ai.AiEmotionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AiEmotionServlet</servlet-name>
        <url-pattern>/api/ai/emotion</url-pattern>
    </servlet-mapping>

    <!-- ==================== Search & Hot Servlets ==================== -->
    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>com.iblog.servlet.search.SearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/api/search</url-pattern>
    </servlet-mapping>

    <servlet>
