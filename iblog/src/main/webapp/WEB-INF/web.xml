        <servlet-class>com.iblog.servlet.social.VisitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VisitServlet</servlet-name>
        <url-pattern>/api/social/visitors</url-pattern>
    </servlet-mapping>

    <!-- ==================== Circle Servlets ==================== -->
    <servlet>
        <servlet-name>CircleListServlet</servlet-name>
        <servlet-class>com.iblog.servlet.circle.CircleListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CircleListServlet</servlet-name>
