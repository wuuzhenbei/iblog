    </servlet-mapping>

    <!-- ==================== Admin Servlets ==================== -->
    <servlet>
        <servlet-name>AdminUserServlet</servlet-name>
        <servlet-class>com.iblog.servlet.admin.AdminUserServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserServlet</servlet-name>
        <url-pattern>/api/admin/users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminContentServlet</servlet-name>
        <servlet-class>com.iblog.servlet.admin.AdminContentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminContentServlet</servlet-name>
        <url-pattern>/api/admin/content</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminCircleServlet</servlet-name>
        <servlet-class>com.iblog.servlet.admin.AdminCircleServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminCircleServlet</servlet-name>
        <url-pattern>/api/admin/circles</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminHotServlet</servlet-name>
        <servlet-class>com.iblog.servlet.admin.AdminHotServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminHotServlet</servlet-name>
        <url-pattern>/api/admin/hot</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminStatsServlet</servlet-name>
        <servlet-class>com.iblog.servlet.admin.AdminStatsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminStatsServlet</servlet-name>
        <url-pattern>/api/admin/stats</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminAiServlet</servlet-name>
        <servlet-class>com.iblog.servlet.admin.AdminAiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminAiServlet</servlet-name>
        <url-pattern>/api/admin/ai</url-pattern>
    </servlet-mapping>

    <!-- Welcome file -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
